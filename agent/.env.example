# Google AI Studio에서 발급받은 Gemini API 키
GEMINI_API_KEY=

# Next.js 서버(route handler)가 이 서버 앞단에서 프록시 역할을 하므로,
# 로컬 개발 환경에서는 보통 http://localhost:3000 하나만 있으면 된다.
# 콤마로 구분해 여러 도메인을 넣을 수 있다. 배포 후 실제 Vercel 도메인을 추가할 것.
ALLOWED_ORIGINS=http://localhost:3000

# 설정하면 /process-schedule, /extract-text 요청에 X-API-Key 헤더 검증을 강제한다
# (미설정 시 인증 생략 — 로컬 개발 기본값). Next.js 쪽 .env.local의 AGENT_API_KEY와
# 반드시 같은 값이어야 하며, 배포 환경에서는 꼭 설정할 것.
AGENT_API_KEY=
