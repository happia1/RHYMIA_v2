# Supabase — 프로젝트 설정 > API에서 확인
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 홈 화면 날씨 카드 — https://openweathermap.org/api 무료 티어로 발급
OPENWEATHER_API_KEY=

# 에이전트 서버(agent/main.py) 연동 — 로컬 개발은 기본값(localhost:8000)이면 충분
NEXT_PUBLIC_AGENT_API_URL=http://localhost:8000
# 에이전트 서버 쪽에서 API 키를 요구하도록 설정했을 때만 필요(선택)
AGENT_API_KEY=

# 끼니 등록 "블로그에서 레시피 찾기" — 네이버 블로그 검색 API.
# 둘 다 없으면 이 기능은 화면에 아예 노출되지 않는다(isRecipeSearchEnabled 게이트).
# 발급: https://developers.naver.com/apps/#/register → Application 등록 →
#   사용 API에서 "검색" 체크 → 등록 후 Application 목록에서 Client ID/Secret 확인
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 식탁 탭 "추천 레시피"/끼니 등록 "레시피(내부) 검색" — 식품안전나라 조리식품 레시피 DB
# (COOKRCP01) OpenAPI. 없으면 해당 기능들이 "준비 중"으로 표시되고 탭 자체가 숨겨진다
# (isFoodSafetyRecipeEnabled 게이트, foodSafetyRecipe.ts 참고).
# 발급: https://www.foodsafetykorea.go.kr/api/openApiInfo.do → 회원가입 후 인증키 신청
FOOD_SAFETY_API_KEY=
